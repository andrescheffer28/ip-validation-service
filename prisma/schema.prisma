// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String  @id @default(uuid())
  name         String
  email        String  @unique
  password     String
  profileImage String? @map("profile_image")

  sentEmails     Email[] @relation("SentEmails")
  receivedEmails Email[] @relation("ReceivedEmails")

  userCookie Cookie[] @relation("UserCookies")

  @@map("users")
}

model Email {
  id         String   @id @default(uuid())
  title      String
  data       DateTime @default(now())
  content    String
  isSeen     Boolean  @default(false) @map("is_seen")
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")

  sender   User @relation("SentEmails", fields: [senderId], references: [id])
  receiver User @relation("ReceivedEmails", fields: [receiverId], references: [id])

  @@map("emails")
}

model Cookie {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  createdAt DateTime  @map("created_at")
  userIP    String    @map("user_ip")
  country   String?  
  city      String?

  userCookie User @relation("UserCookies", fields: [userId], references: [id])

  @@map("cookies")
}
